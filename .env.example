# X (Twitter) API — https://developer.x.com/en/portal/dashboard
X_API_KEY=
X_API_SECRET=
X_BEARER_TOKEN=
# OAuth 2.0 User Context (for posting) — run ./scripts/x-auth.sh to refresh
X_CLIENT_ID=
